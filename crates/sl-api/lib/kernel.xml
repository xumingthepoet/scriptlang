<module name="kernel">
  <macro name="if" attributes="when:expr" content="ast">
    <let name="when_expr" type="expr">
      <get-attribute name="when"/>
    </let>
    <let name="content_ast" type="ast">
      <get-content/>
    </let>
    <quote>
      <temp name="condition" type="bool">
        <unquote>when_expr</unquote>
      </temp>
      <while when="condition" __sl_loop_capture="false">
        <code>condition = false;</code>
        <unquote>content_ast</unquote>
      </while>
    </quote>
  </macro>
  <macro name="unless" attributes="when:expr" content="ast">
    <let name="when_expr" type="expr">
      <get-attribute name="when"/>
    </let>
    <let name="content_ast" type="ast">
      <get-content/>
    </let>
    <quote>
      <temp name="condition" type="bool">
        <unquote>when_expr</unquote>
      </temp>
      <while when="!condition" __sl_loop_capture="false">
        <code>condition = true;</code>
        <unquote>content_ast</unquote>
      </while>
    </quote>
  </macro>
  <macro name="if-else" attributes="when:expr" content="ast">
    <let name="when_expr" type="expr">
      <get-attribute name="when"/>
    </let>
    <let name="do_ast" type="ast">
      <get-content head="do"/>
    </let>
    <let name="else_ast" type="ast">
      <get-content head="else"/>
    </let>
    <quote>
      <temp name="condition" type="bool">
        <unquote>when_expr</unquote>
      </temp>
      <temp name="else_condition" type="bool">!condition</temp>
      <while when="condition" __sl_loop_capture="false">
        <code>condition = false;</code>
        <unquote>do_ast</unquote>
      </while>
      <while when="else_condition" __sl_loop_capture="false">
        <code>else_condition = false;</code>
        <unquote>else_ast</unquote>
      </while>
    </quote>
  </macro>
</module>
