<module name="kernel">
  <const name="zero" type="int">0</const>
  <macro name="if" attributes="when:expr" content="ast">
    <let name="when_expr" type="expr">
      <get-attribute name="when"/>
    </let>
    <let name="content_ast" type="ast">
      <get-content/>
    </let>
    <quote>
      <temp name="condition" type="bool">
        <unquote>when_expr</unquote>
      </temp>
      <while when="condition" __sl_loop_capture="false">
        <code>condition = false;</code>
        <unquote>content_ast</unquote>
      </while>
    </quote>
  </macro>
  <macro name="say" attributes="text:string">
    <let name="text_value" type="string">
      <get-attribute name="text"/>
    </let>
    <quote>
      <text>${text_value}</text>
    </quote>
  </macro>
  <macro name="when_text" attributes="when:expr" content="ast">
    <let name="when_expr" type="expr">
      <get-attribute name="when"/>
    </let>
    <let name="content_ast" type="ast">
      <get-content/>
    </let>
    <quote>
      <if when="${when_expr}">
        <unquote>content_ast</unquote>
      </if>
    </quote>
  </macro>
  <macro name="script_text" attributes="name:string,text:string">
    <let name="script_name" type="string">
      <get-attribute name="name"/>
    </let>
    <let name="text_value" type="string">
      <get-attribute name="text"/>
    </let>
    <quote>
      <script name="${script_name}">
        <text>${text_value}</text>
        <end/>
      </script>
    </quote>
  </macro>
  <macro name="unless" attributes="when:expr" content="ast">
    <let name="when_expr" type="expr">
      <get-attribute name="when"/>
    </let>
    <let name="content_ast" type="ast">
      <get-content/>
    </let>
    <quote>
      <temp name="condition" type="bool">
        <unquote>when_expr</unquote>
      </temp>
      <if when="!condition">
        <unquote>content_ast</unquote>
      </if>
    </quote>
  </macro>
  <macro name="if-else" attributes="when:expr" content="ast">
    <let name="when_expr" type="expr">
      <get-attribute name="when"/>
    </let>
    <let name="do_ast" type="ast">
      <get-content head="do"/>
    </let>
    <let name="else_ast" type="ast">
      <get-content head="else"/>
    </let>
    <quote>
      <temp name="condition" type="bool">
        <unquote>when_expr</unquote>
      </temp>
      <if when="condition">
        <unquote>do_ast</unquote>
      </if>
      <if when="!condition">
        <unquote>else_ast</unquote>
      </if>
    </quote>
  </macro>
</module>
