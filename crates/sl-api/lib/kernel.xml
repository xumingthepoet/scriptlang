<module name="kernel">
  <macro name="if" params="expr:when,ast:body">
    <quote>
      <temp name="condition" type="bool">
        <unquote>when</unquote>
      </temp>
      <while when="condition" __sl_skip_loop_control_capture="true">
        <code>condition = false;</code>
        <unquote>body</unquote>
      </while>
    </quote>
  </macro>
  <macro name="unless" params="expr:when,ast:body">
    <quote>
      <temp name="condition" type="bool">
        <unquote>when</unquote>
      </temp>
      <while when="!condition" __sl_skip_loop_control_capture="true">
        <code>condition = true;</code>
        <unquote>body</unquote>
      </while>
    </quote>
  </macro>
  <macro name="if-else" params="expr:when">
    <let name="do_ast" type="ast">
      <get-content head="do"/>
    </let>
    <let name="else_ast" type="ast">
      <get-content head="else"/>
    </let>
    <quote>
      <temp name="condition" type="bool">
        <unquote>when</unquote>
      </temp>
      <temp name="else_condition" type="bool">!condition</temp>
      <while when="condition" __sl_skip_loop_control_capture="true">
        <code>condition = false;</code>
        <unquote>do_ast</unquote>
      </while>
      <while when="else_condition" __sl_skip_loop_control_capture="true">
        <code>else_condition = false;</code>
        <unquote>else_ast</unquote>
      </while>
    </quote>
  </macro>
  <!-- Step 5: Elixir-style use macro -->
  <!-- use: requires module + invokes target.__using__(opts) -->
  <macro name="use" params="string:module,keyword:opts">
    <let name="resolved" type="string">
      <require_module>
        <var name="module"/>
      </require_module>
    </let>
    <invoke_macro module="resolved" macro_name="__using__" opts="opts"/>
  </macro>
</module>
