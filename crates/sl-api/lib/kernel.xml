<module name="kernel">
  <const name="zero" type="int">0</const>
  <macro name="say" scope="statement">
    <text>{{text}}</text>
  </macro>
  <macro name="when_text" scope="statement">
    <if when="{{when}}">
      <yield/>
    </if>
  </macro>
  <macro name="script_text" scope="module">
    <script name="{{name}}">
      <text>{{text}}</text>
      <end/>
    </script>
  </macro>
  <macro name="unless" scope="statement" attributes="when:expr" content="ast">
    <let name="when_expr" type="expr">
      <get-attribute name="when"/>
    </let>
    <let name="content_ast" type="ast">
      <get-content/>
    </let>
    <quote>
      <temp name="condition" type="bool">
        <unquote>when_expr</unquote>
      </temp>
      <if when="!condition">
        <unquote>content_ast</unquote>
      </if>
    </quote>
  </macro>
  <macro name="if-else" scope="statement" attributes="when:expr" content="ast">
    <let name="when_expr" type="expr">
      <get-attribute name="when"/>
    </let>
    <let name="do_ast" type="ast">
      <get-content head="do"/>
    </let>
    <let name="else_ast" type="ast">
      <get-content head="else"/>
    </let>
    <quote>
      <temp name="condition" type="bool">
        <unquote>when_expr</unquote>
      </temp>
      <if when="condition">
        <unquote>do_ast</unquote>
      </if>
      <if when="!condition">
        <unquote>else_ast</unquote>
      </if>
    </quote>
  </macro>
</module>
