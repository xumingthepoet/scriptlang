<module name="main">
  <const name="base" type="int">1</const>
  <const name="bonus" type="array">[base, 2]</const>
  <script name="main">
    <temp name="x" type="int">bonus[0] + bonus[1]</temp>
    <text tag="line">${base} ${x}</text>
    <choice text="pick ${base}">
      <option text="go ${bonus[1]}">
        <end/>
      </option>
    </choice>
  </script>
</module>
